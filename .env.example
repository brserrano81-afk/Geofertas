# ============================================================
# EconomizaFacil.IA — Environment Variables
# Copy this to backend/.env and fill in the values
# ============================================================

# App
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# Database (Supabase PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:5432/database
DATABASE_URL=postgresql+asyncpg://postgres.XXXX:password@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_SMART=claude-sonnet-4-6

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=economizafacil-dev-key
EVOLUTION_INSTANCE=economizafacil

# Redis
REDIS_URL=redis://localhost:6379/0

# WhatsApp bot phone number (international, no + or spaces)
BOT_PHONE=5527XXXXXXXXX

# Webhook secret (any random string for request validation)
WEBHOOK_SECRET=your-random-secret-here

# Fuel defaults (used when user hasn't informed their vehicle data)
DEFAULT_FUEL_PRICE=5.89
DEFAULT_FUEL_EFFICIENCY=10.0

# ---- For Frontend (Supabase) ----
# VITE_SUPABASE_URL=https://XXXX.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGc...
# VITE_API_URL=http://localhost:8000
# VITE_BOT_PHONE=5527XXXXXXXXX
