rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // ARQUITETURA "COFRE" - Geofertas
    // ---------------------------------------------------------
    
    // Bloqueio Global (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Acesso Administrativo (Temporário para MVP)
    // TODO: Migrar para Firebase Auth + Custom Claims para segurança real.
    // Atualmente permite acesso pelo painel administrativo para as coleções operacionais.
    match /markets/{market} {
      allow read, write: if true; 
    }
    match /offers/{offer} {
      allow read, write: if true;
    }
    match /campaigns/{campaign} {
      allow read, write: if true;
    }
    match /offer_queue/{item} {
      allow read, write: if true;
    }
    
    // Coleções de Usuários - Blindagem Total (Apenas via Backend)
    match /users/{user} {
      allow read, write: if false;
    }
    match /user_interactions/{interaction} {
      allow read, write: if false;
    }
    match /user_lists/{list} {
      allow read, write: if false;
    }
  }
}
