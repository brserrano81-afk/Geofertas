{
  "name": "geofertas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "whatsapp": "vite-node src/whatsapp/WhatsappBridge.ts",
    "worker:evolution": "tsx src/workers/EvolutionInboxWorker.ts",
    "worker:evolution:once": "tsx src/workers/EvolutionInboxWorker.ts --once --verbose",
    "test:evolution:webhook": "tsx src/scripts/testEvolutionWebhook.ts",
    "catalog:seed-popular": "tsx src/scripts/upsertPopularCatalogProducts.ts",
    "catalog:coverage": "tsx src/scripts/reportCatalogCoverage.ts",
    "catalog:staple-template": "tsx src/scripts/generateStapleGapTemplate.ts",
    "catalog:import-staples": "tsx src/scripts/importStapleOffersFromCsv.ts",
    "offers:test-seed": "tsx src/scripts/seedTestOfferUniverse.ts",
    "offers:test-clear": "tsx src/scripts/clearTestOfferUniverse.ts",
    "offers:report": "tsx src/scripts/reportOfferHygiene.ts",
    "offers:archive-bad": "tsx src/scripts/archiveBadOffers.ts",
    "proxy": "node api/sefaz-proxy.js",
    "stack:evolution:start": "powershell -ExecutionPolicy Bypass -File scripts/start-evolution-stack.ps1",
    "stack:evolution:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-evolution-stack.ps1",
    "start:all": "concurrently \"npm run proxy\" \"npm run whatsapp\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.577.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0"
  }
}
